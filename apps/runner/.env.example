DATABASE_URL=postgresql://postgres:postgres@localhost:5432/openworkspace

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Must match the ENCRYPTION_SECRET in apps/api/.env
ENCRYPTION_SECRET=change-me-32-chars-minimum-secret

RUNNER_INSTANCE=runner-1

# ── E2B Sandbox ───────────────────────────────────────────────────────────────
# Optional: global fallback API key for E2B sandbox execution.
# Recommended: store per-workspace via the workspace settings UI instead.
# Get your key at https://e2b.dev
# E2B_API_KEY=e2b_...

# ── Proxy (optional) ──────────────────────────────────────────────────────────
# HTTP_PROXY=http://127.0.0.1:1087
# HTTPS_PROXY=http://127.0.0.1:1087
