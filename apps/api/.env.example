# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/openworkspace"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
# Get these from Firebase Console → Project Settings → Service Accounts
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── Auth ──────────────────────────────────────────────────────────────────────
# JWT secret for human user tokens (HS256)
JWT_SECRET="change-me-in-production-use-openssl-rand-hex-32"

# ── Encryption ────────────────────────────────────────────────────────────────
# 32+ character random string used for AES-256-GCM resource key encryption
# Generate with: openssl rand -hex 32
ENCRYPTION_SECRET="change-me-use-openssl-rand-hex-32"

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── App ───────────────────────────────────────────────────────────────────────
WEB_URL="http://localhost:3000"
PORT=3001

# ── Proxy (optional) ──────────────────────────────────────────────────────────
# HTTP_PROXY=http://127.0.0.1:1087
# HTTPS_PROXY=http://127.0.0.1:1087
