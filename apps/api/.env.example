# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/openworkspace"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Production: set CLERK_JWKS_URL (Clerk RS256 tokens)
# Development: set JWT_SECRET (HS256 fallback, any random string)
CLERK_JWKS_URL="https://<your-clerk-domain>.clerk.accounts.dev/.well-known/jwks.json"
# JWT_SECRET="change-me-in-development"

# ── Encryption ────────────────────────────────────────────────────────────────
# 32+ character random string used for AES-256-GCM resource key encryption
ENCRYPTION_SECRET="change-me-use-openssl-rand-hex-32"

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── App ───────────────────────────────────────────────────────────────────────
WEB_URL="http://localhost:3000"
PORT=3001
