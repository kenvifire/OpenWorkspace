generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users & Workspaces ───────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  firebaseUid   String   @unique
  email     String   @unique
  name      String
  avatarUrl                  String?
  planningAgentDefaultPrompt   String?  @db.Text
  planningAgentProvider        String?
  planningAgentModel           String?
  planningAgentEncryptedApiKey String?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  workspaceMemberships WorkspaceMember[]
  ownedWorkspaces      Workspace[]
  ledProjects          Project[]
  agentProvider        AgentProvider?
  personalAgents       Agent[]          @relation("PersonalAgents")
  skills               Skill[]          @relation("UserSkills")
  mcps                 Mcp[]            @relation("UserMcps")
  reviews              AgentReview[]
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner        User                   @relation(fields: [ownerId], references: [id])
  members      WorkspaceMember[]
  projects     Project[]
  providerKeys WorkspaceProviderKey[]
}

model WorkspaceProviderKey {
  id           String   @id @default(cuid())
  workspaceId  String
  provider     String   // openai | anthropic | gemini | custom
  label        String?
  encryptedKey String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, provider])
}

model WorkspaceMember {
  id          String              @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceMemberRole @default(MEMBER)
  joinedAt    DateTime            @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

enum WorkspaceMemberRole {
  OWNER
  MEMBER
}

// ─── Projects ─────────────────────────────────────────────────────────────────

model Project {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  description String   @db.Text
  leaderId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customNdaFileKey      String?  // S3 key; if set, all hires use this NDA instead of platform default
  plannerProjectAgentId String?  // ProjectAgent designated as planner
  sandboxProvider       String?  @default("e2b")  // Sandbox provider for agent runs: "e2b" | null

  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  leader         User            @relation(fields: [leaderId], references: [id])
  plannerAgent   ProjectAgent?   @relation("ProjectPlanner", fields: [plannerProjectAgentId], references: [id])
  projectAgents  ProjectAgent[]
  tasks          Task[]
  resourceKeys   ResourceKey[]
  billingRecords  BillingRecord[]
  planningAgent   ProjectPlanningAgent?
  plannerRunLogs  PlannerRunLog[]
}

model ResourceKey {
  id             String   @id @default(cuid())
  projectId      String
  name           String
  description    String?
  encryptedValue String
  createdAt      DateTime @default(now())
  createdById    String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ─── Agents & Marketplace ─────────────────────────────────────────────────────

// ─── Agreements ───────────────────────────────────────────────────────────────

model ProviderDpaAcceptance {
  id          String   @id @default(cuid())
  providerId  String
  dpaVersion  String
  acceptedAt  DateTime @default(now())
  ipAddress   String?

  provider AgentProvider @relation(fields: [providerId], references: [id])
}

model ProjectAgreement {
  id               String              @id @default(cuid())
  projectAgentId   String              @unique
  agreementType    ProjectAgreementType
  customNdaFileKey String?             // S3 key for custom NDA PDF
  acceptedAt       DateTime            @default(now())
  acceptedById     String              // userId (human) or providerId (AI agent)
  acceptedByType   String              // 'user' | 'provider'
  signatureRef     String?             // DocuSign envelope ID for human agents
  dpaVersionInEffect String

  projectAgent ProjectAgent @relation(fields: [projectAgentId], references: [id])
}

enum ProjectAgreementType {
  PLATFORM_DEFAULT
  CUSTOM_NDA
}

model AgentProvider {
  id                String   @id @default(cuid())
  userId            String   @unique
  displayName       String
  bio               String?  @db.Text
  kycVerified       Boolean  @default(false)
  kycVerifiedAt     DateTime?
  activeDpaVersion  String?
  createdAt         DateTime @default(now())

  user           User                   @relation(fields: [userId], references: [id])
  agents         Agent[]
  dpaAcceptances ProviderDpaAcceptance[]
}

model Agent {
  id              String       @id @default(cuid())
  providerId      String?      // null for personal agents
  userId          String?      // set for personal agents (owned directly by a user)
  name            String
  description     String       @db.Text
  type            AgentType    @default(AI)
  pricingModel    PricingModel @default(PER_JOB)
  pricePerJob     Int?
  pricePerToken   Int?
  capabilityTags  String[]     @default([])
  isPublished     Boolean      @default(false)
  aggregateRating Float?
  reviewCount     Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // LLM config (AI agents)
  llmProvider     String?      // openai | anthropic | gemini | custom
  modelName       String?
  systemPrompt    String?      @db.Text
  encryptedApiKey String?      // AES-256-GCM encrypted; overrides workspace provider key
  temperature     Float?
  maxTokens       Int?
  maxIterations   Int?         @default(20)
  enabledTools    String[]     @default([])

  activeVersionId String?

  provider      AgentProvider? @relation(fields: [providerId], references: [id])
  owner         User?          @relation("PersonalAgents", fields: [userId], references: [id])
  projectAgents ProjectAgent[]
  reviews       AgentReview[]
  runLogs       AgentRunLog[]
  skills        AgentSkill[]
  mcps          AgentMcp[]
  versions      AgentVersion[]
}

model AgentVersion {
  id            String   @id @default(cuid())
  agentId       String
  versionNumber Int
  label         String?
  // snapshot of agent config at publish time
  name          String
  description   String   @db.Text
  systemPrompt  String?  @db.Text
  llmProvider   String?
  modelName     String?
  temperature   Float?
  maxTokens     Int?
  maxIterations Int?
  enabledTools  String[] @default([])
  publishedAt   DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, versionNumber])
}

// ─── Skills ───────────────────────────────────────────────────────────────────

model Skill {
  id           String    @id @default(cuid())
  userId       String
  name         String
  description  String
  instructions String    @db.Text
  type         SkillType @default(PROMPT)

  // Webhook config (type = WEBHOOK)
  webhookUrl     String?
  webhookMethod  String?  // GET | POST | PUT | DELETE
  webhookHeaders String?  // JSON: { "Authorization": "Bearer ..." }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner         User                @relation("UserSkills", fields: [userId], references: [id])
  agents        AgentSkill[]
  projectAgents ProjectAgentSkill[]
}

enum SkillType {
  PROMPT
  WEBHOOK
}

model AgentSkill {
  id      String @id @default(cuid())
  agentId String
  skillId String

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([agentId, skillId])
}

model ProjectAgentSkill {
  id             String   @id @default(cuid())
  projectAgentId String
  skillId        String
  assignedAt     DateTime @default(now())

  projectAgent ProjectAgent @relation(fields: [projectAgentId], references: [id], onDelete: Cascade)
  skill        Skill        @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([projectAgentId, skillId])
}

enum AgentType {
  AI
  HUMAN
}

// ─── MCPs ─────────────────────────────────────────────────────────────────────

enum McpTransport {
  SSE
  HTTP
  STDIO
}

model Mcp {
  id          String       @id @default(cuid())
  userId      String
  name        String
  description String
  transport   McpTransport @default(SSE)
  url         String?      // for SSE / HTTP
  command     String?      // for STDIO (the executable)
  args        String[]     // for STDIO (command arguments)
  headers     String?      // JSON string for custom request headers
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  owner         User              @relation("UserMcps", fields: [userId], references: [id])
  agents        AgentMcp[]
  projectAgents ProjectAgentMcp[]
}

model AgentMcp {
  id        String   @id @default(cuid())
  agentId   String
  mcpId     String
  createdAt DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  mcp   Mcp   @relation(fields: [mcpId], references: [id], onDelete: Cascade)

  @@unique([agentId, mcpId])
}

model ProjectAgentMcp {
  id             String   @id @default(cuid())
  projectAgentId String
  mcpId          String
  assignedAt     DateTime @default(now())

  projectAgent ProjectAgent @relation(fields: [projectAgentId], references: [id], onDelete: Cascade)
  mcp          Mcp          @relation(fields: [mcpId], references: [id], onDelete: Cascade)

  @@unique([projectAgentId, mcpId])
}

enum PricingModel {
  PER_JOB
  PER_TOKEN
}

model ProjectAgent {
  id            String      @id @default(cuid())
  projectId     String
  agentId       String
  role          ProjectRole
  customRole    String?
  isCoordinator Boolean     @default(false)
  projectKey    String      @unique
  hiredAt       DateTime    @default(now())
  hiredById     String
  revokedAt     DateTime?

  project           Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  agent             Agent            @relation(fields: [agentId], references: [id])
  assignedTasks     Task[]
  billingRecords    BillingRecord[]
  agreement         ProjectAgreement?
  runLogs           AgentRunLog[]
  plannerForProjects Project[]       @relation("ProjectPlanner")
  skills            ProjectAgentSkill[]
  mcps              ProjectAgentMcp[]

  @@unique([projectId, agentId])
}

enum ProjectRole {
  LEADER
  COORDINATOR
  DEVELOPER
  REVIEWER
  DESIGNER
  QA
  CUSTOM
}

model AgentReview {
  id               String   @id @default(cuid())
  agentId          String
  projectId        String
  reviewerId       String
  rating           Int
  comment          String?  @db.Text
  providerResponse String?  @db.Text
  createdAt        DateTime @default(now())

  agent    Agent @relation(fields: [agentId], references: [id])
  reviewer User  @relation(fields: [reviewerId], references: [id])

  @@unique([agentId, projectId, reviewerId])
}

// ─── Kanban / Tasks ───────────────────────────────────────────────────────────

model Task {
  id           String       @id @default(cuid())
  projectId    String
  title        String
  description  String?      @db.Text
  status       TaskStatus   @default(BACKLOG)
  priority     TaskPriority @default(MEDIUM)
  assigneeId   String?
  reporterId   String
  reporterType String
  dueDate      DateTime?
  deletedAt    DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  project    Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee   ProjectAgent?  @relation(fields: [assigneeId], references: [id])
  comments   TaskComment[]
  activities TaskActivity[]
  runLogs    AgentRunLog[]
  blockedBy  TaskDependency[] @relation("BlockedTask")
  blocking   TaskDependency[] @relation("BlockingTask")
}

model TaskDependency {
  id             String @id @default(cuid())
  blockingTaskId String
  blockedTaskId  String

  blockingTask Task @relation("BlockingTask", fields: [blockingTaskId], references: [id], onDelete: Cascade)
  blockedTask  Task @relation("BlockedTask",  fields: [blockedTaskId],  references: [id], onDelete: Cascade)

  @@unique([blockingTaskId, blockedTaskId])
  @@index([blockedTaskId])
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model TaskComment {
  id         String   @id @default(cuid())
  taskId     String
  authorId   String
  authorType String
  content    String   @db.Text
  createdAt  DateTime @default(now())

  task  Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model TaskActivity {
  id        String   @id @default(cuid())
  taskId    String
  actorId   String
  actorType String
  action    String
  metadata  Json?
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

// ─── Agent Run Logs ───────────────────────────────────────────────────────────

model AgentRunLog {
  id             String         @id @default(cuid())
  taskId         String
  agentId        String
  projectAgentId String
  status             AgentRunStatus @default(RUNNING)
  iterations         Int            @default(0)
  totalInputTokens   Int            @default(0)
  totalOutputTokens  Int            @default(0)
  startedAt          DateTime       @default(now())
  finishedAt         DateTime?
  log                Json           @default("[]") // array of step objects

  task         Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  agent        Agent        @relation(fields: [agentId], references: [id])
  projectAgent ProjectAgent @relation(fields: [projectAgentId], references: [id])

  @@index([taskId])
  @@index([agentId])
  @@index([projectAgentId])
}

enum AgentRunStatus {
  RUNNING
  COMPLETED
  STOPPED
  FAILED
  MAX_ITERATIONS
}

// ─── Billing ──────────────────────────────────────────────────────────────────

model BillingRecord {
  id             String       @id @default(cuid())
  workspaceId    String
  projectId      String
  projectAgentId String
  event          BillingEvent
  pricingModel   PricingModel
  amountCents    Int
  tokenCount     Int?
  description    String
  createdAt      DateTime     @default(now())

  project      Project      @relation(fields: [projectId], references: [id])
  projectAgent ProjectAgent @relation(fields: [projectAgentId], references: [id])
}

enum BillingEvent {
  JOB_COMPLETED
  TOKEN_USAGE
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id             String   @id @default(cuid())
  workspaceId    String
  projectId      String?
  actorId        String   // projectAgentId or userId
  actorType      String   // 'agent' | 'user'
  action         String   // e.g. 'READ_RESOURCE_KEY', 'UPDATE_TASK', 'READ_PROJECT'
  resourceType   String   // e.g. 'ResourceKey', 'Task', 'Project'
  resourceId     String?
  metadata       Json?
  ipAddress      String?
  createdAt      DateTime @default(now())

  @@index([workspaceId, createdAt])
  @@index([projectId, actorId])
}

// ─── Project Planning Agent ───────────────────────────────────────────────────

model ProjectPlanningAgent {
  id              String   @id @default(cuid())
  projectId       String   @unique
  customPrompt    String?  @db.Text
  activeVersionId String?  // plain string ref, no FK relation
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project  Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versions PlanningAgentVersion[]
}

model PlanningAgentVersion {
  id              String   @id @default(cuid())
  planningAgentId String
  versionNumber   Int
  label           String?
  customPrompt    String?  @db.Text
  publishedAt     DateTime @default(now())

  planningAgent ProjectPlanningAgent @relation(fields: [planningAgentId], references: [id], onDelete: Cascade)
}

// ─── Planner Run Log ──────────────────────────────────────────────────────────

model PlannerRunLog {
  id                  String    @id @default(cuid())
  projectId           String
  status              String    @default("COMPLETED") // COMPLETED | FAILED
  descriptionSnapshot String?   @db.Text
  planOutput          Json?     // the generated plan { roles, tasks }
  error               String?   @db.Text
  totalInputTokens    Int       @default(0)
  totalOutputTokens   Int       @default(0)
  startedAt           DateTime  @default(now())
  finishedAt          DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, startedAt])
}
