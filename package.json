{
  "name": "openworkspace",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter './apps/api' --filter './apps/app' --filter './apps/runner' dev",
    "dev:all": "pnpm --parallel --filter './apps/*' dev",
    "build": "pnpm --filter './packages/*' build && pnpm --filter './apps/*' build",
    "lint": "pnpm --parallel --filter './apps/*' --filter './packages/*' lint",
    "type-check": "pnpm --parallel --filter './apps/*' --filter './packages/*' type-check"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@clerk/shared",
      "@nestjs/core",
      "@parcel/watcher",
      "@prisma/client",
      "@prisma/engines",
      "@swc/core",
      "bcrypt",
      "msgpackr-extract",
      "msw",
      "prisma"
    ]
  }
}
